# ---------------------------------------------------------------------------
# WhataHotel AI Advisor — environment
# ---------------------------------------------------------------------------
# The app runs fully WITHOUT any keys (deterministic "advisor" engine + mock
# luxury inventory). Add keys to upgrade individual services to live data.
# Every service is modular: a missing key transparently falls back to mock.
# ---------------------------------------------------------------------------

# --- AI model (optional) ----------------------------------------------------
# When present, the advisor uses Claude via the Vercel AI SDK for natural
# language understanding + streaming replies. When absent, a built-in
# deterministic advisor engine takes over so the experience still works.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5

# --- Amadeus Hotel APIs (optional) -----------------------------------------
# Search / Details / Availability / Pricing. Missing => mock inventory.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# --- Google Places (optional) ----------------------------------------------
# Enriches hotels with real guest ratings + photos. Used only by
# scripts/enrich-places.mjs (server-side, one-time). Enable "Places API (New)".
GOOGLE_PLACES_API_KEY=

# --- WhataHotel API (from Matt) --------------------------------------------
# Server-side only (key is a URL variable — never exposed to the browser).
WHATAHOTEL_API_URL=
WHATAHOTEL_API_KEY=

# --- WhataHotel advisor perks service (optional) ---------------------------
WHATAHOTEL_PERKS_API_URL=
WHATAHOTEL_PERKS_API_KEY=

# --- Authentication --------------------------------------------------------
# Secret used to sign session JWTs (HS256). MUST be set to a long random string
# in production — generate one with:  openssl rand -hex 32
AUTH_SECRET=

# --- CRM / lead capture ----------------------------------------------------
# The account allowed to see the Leads (CRM) dashboard at /dashboard/leads.
# Defaults to info@lorrainetravel.com. Create an account with this email to view.
ADMIN_EMAIL=info@lorrainetravel.com

# --- Email alerts (optional, recommended) ----------------------------------
# When a guest asks to speak with a human advisor, the team is emailed at
# ADMIN_EMAIL (in addition to the browser desktop notification). Uses Resend
# (https://resend.com) — a fetch-only API, no package to install. Without a key
# this is a graceful no-op (the in-app "Needs agent" flag + desktop alert still
# work). To enable: create a Resend account, verify your sending domain, then:
#   RESEND_API_KEY   — from the Resend dashboard
#   EMAIL_FROM       — a verified sender, e.g.  WhataHotel <alerts@yourdomain.com>
RESEND_API_KEY=
EMAIL_FROM=WhataHotel <onboarding@resend.dev>

# --- Web Push alerts (optional) --------------------------------------------
# Pushes a live-agent alert to the team's phone/desktop even with the browser
# CLOSED (no tab open). The admin enables it from the Conversations dashboard
# ("Enable alerts"). Without keys this is a graceful no-op (desktop + email
# alerts still work). Generate the pair ONCE with:
#     npx web-push generate-vapid-keys
# then paste them here. VAPID_SUBJECT is a mailto: contact for push services.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@lorrainetravel.com

# --- Google sign-in (optional) ---------------------------------------------
# When both are set, "Continue with Google" activates at the sign-up gate.
# Create an OAuth client at https://console.cloud.google.com (Web application),
# add the redirect URI  https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where the bundled file-based data store persists accounts/trips. Defaults to
# the OS temp dir (fine for dev + a warm serverless instance).
DATA_DIR=

# --- Durable data store (recommended for production) -----------------------
# Set these to make accounts/trips/subscriptions fully durable + consistent
# across serverless instances. The store auto-switches to Redis when present.
#
# Easiest: add "Vercel KV" (Marketplace → Upstash) to the project — Vercel then
# injects KV_REST_API_URL + KV_REST_API_TOKEN automatically. Or use a standalone
# Upstash Redis database and set the UPSTASH_* pair. No package to install.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
